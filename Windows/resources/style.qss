/* ============================================================
   Memories - Light Theme
   Enhanced visual hierarchy with clear separation
   ============================================================ */

/* ---- Tooltip ---- */
QToolTip {
    background: #ffffff;
    color: #1e293b;
    border: 2px solid #94a3b8;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 500;
}

/* ---- Global ---- */
* {
    font-family: "Noto Sans SC", "WenQuanYi Micro Hei", "Sans Serif";
    font-size: 13px;
    color: #1e293b;
    line-height: 1.6;
}

QMainWindow {
    background: #f1f5f9;
}

QWidget#centralWidget {
    background: #f8fafc;
    margin: 8px;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
}

/* ---- Scroll Areas ---- */
QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background: transparent;
}

QScrollBar:vertical {
    background: #e2e8f0;
    width: 10px;
    border-radius: 5px;
    margin: 4px 0;
}
QScrollBar::handle:vertical {
    background: #94a3b8;
    border-radius: 5px;
    min-height: 40px;
}
QScrollBar::handle:vertical:hover {
    background: #64748b;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    border: none;
}
QScrollBar:horizontal {
    background: #e2e8f0;
    height: 10px;
    border-radius: 5px;
    margin: 0 4px;
}
QScrollBar::handle:horizontal {
    background: #94a3b8;
    border-radius: 5px;
    min-width: 40px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    border: none;
}

/* ---- Menubar ---- */
QMenuBar {
    background: #ffffff;
    border-bottom: 2px solid #cbd5e1;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
}

QMenuBar::item {
    padding: 6px 16px;
    margin: 2px 4px;
    border-radius: 6px;
    background: transparent;
    color: #334155;
}

QMenuBar::item:selected {
    background: #ecfdf5;
    color: #1D6E5A;
}

QMenu {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 10px;
    padding: 6px;
}

QMenu::item {
    padding: 10px 32px 10px 18px;
    margin: 2px 6px;
    border-radius: 6px;
    color: #334155;
}

QMenu::item:selected {
    background: #ecfdf5;
    color: #1D6E5A;
}

/* ---- Toolbar ---- */
QToolBar {
    background: #ffffff;
    border-bottom: 2px solid #cbd5e1;
    padding: 6px 12px;
    spacing: 8px;
}

QToolBar QToolButton {
    padding: 8px 16px;
    margin: 2px;
    border-radius: 8px;
    color: #334155;
    font-weight: 600;
    font-size: 13px;
    border: 2px solid #cbd5e1;
    background: #f8fafc;
}

QToolBar QToolButton:hover {
    background: #ecfdf5;
    border-color: #1D6E5A;
    color: #1D6E5A;
}

QToolBar QToolButton:pressed {
    background: #d1fae5;
}

QToolBar QToolButton:disabled {
    color: #94a3b8;
    border-color: transparent;
    background: transparent;
}

/* ---- Status Bar ---- */
QStatusBar {
    background: #ffffff;
    border-top: 2px solid #cbd5e1;
    padding: 6px 16px;
    font-size: 12px;
    color: #64748b;
}

QStatusBar QLabel {
    color: #64748b;
    font-size: 12px;
}

/* ---- Push Buttons ---- */
QPushButton {
    padding: 10px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 13px;
    border: 2px solid transparent;
    min-height: 24px;
}

/* Primary button */
QPushButton[accent="true"], QPushButton#primaryBtn {
    background: #1D6E5A;
    color: white;
    border: none;
    font-weight: 700;
}

QPushButton[accent="true"]:hover, QPushButton#primaryBtn:hover {
    background: #165A48;
}

QPushButton[accent="true"]:pressed, QPushButton#primaryBtn:pressed {
    background: #134D3E;
}

/* Secondary / flat button */
QPushButton[flat="true"] {
    background: #f8fafc;
    border: 2px solid #cbd5e1;
    color: #475569;
}

QPushButton[flat="true"]:hover {
    background: #f1f5f9;
    border-color: #1D6E5A;
    color: #1D6E5A;
}

QPushButton[flat="true"]:pressed {
    background: #e2e8f0;
}

/* Default button (not accent/flat) */
QPushButton {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    color: #334155;
}

QPushButton:hover {
    border-color: #1D6E5A;
    color: #1D6E5A;
}

QPushButton:pressed {
    background: #f1f5f9;
}

/* ---- Line Edit ---- */
QLineEdit {
    padding: 10px 16px;
    border-radius: 8px;
    border: 2px solid #cbd5e1;
    background: #ffffff;
    color: #1e293b;
    font-size: 13px;
    selection-background-color: #ecfdf5;
}

QLineEdit:focus {
    border-color: #1D6E5A;
}

QLineEdit:readonly {
    background: #f8fafc;
    color: #64748b;
}

/* ---- ComboBox ---- */
QComboBox {
    padding: 10px 16px;
    border-radius: 8px;
    border: 2px solid #cbd5e1;
    background: #ffffff;
    color: #1e293b;
    font-size: 13px;
    min-width: 140px;
}

QComboBox:hover {
    border-color: #94a3b8;
}

QComboBox:focus {
    border-color: #1D6E5A;
}

QComboBox::drop-down {
    border: none;
    padding-right: 8px;
}

QComboBox QAbstractItemView {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 8px;
    padding: 6px;
    selection-background-color: #ecfdf5;
}

/* ---- SpinBox ---- */
QSpinBox {
    padding: 10px 14px;
    border-radius: 8px;
    border: 2px solid #cbd5e1;
    background: #ffffff;
    color: #1e293b;
    font-size: 13px;
}

QSpinBox:focus {
    border-color: #1D6E5A;
}

/* ---- Checkbox ---- */
QCheckBox {
    spacing: 10px;
    color: #334155;
    font-size: 13px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    border: 2px solid #94a3b8;
    background: #ffffff;
}

QCheckBox::indicator:checked {
    background: #1D6E5A;
    border-color: #1D6E5A;
}

QCheckBox::indicator:hover {
    border-color: #1D6E5A;
}

/* ---- GroupBox (cards) ---- */
QGroupBox {
    background: #ffffff;
    border: 2px solid #94a3b8;
    border-radius: 16px;
    margin-top: 24px;
    padding: 28px 20px 20px 20px;
    font-weight: 700;
    font-size: 14px;
    color: #1e293b;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 6px 16px;
    margin-left: 20px;
    background: #ffffff;
    border-radius: 8px;
    border: 2px solid #94a3b8;
}

/* ---- Tab Widget ---- */
QTabWidget::pane {
    background: #ffffff;
    border: 2px solid #94a3b8;
    border-radius: 10px;
    padding: 12px;
}

QTabBar::tab {
    padding: 10px 24px;
    margin: 4px 6px;
    border-radius: 8px;
    background: transparent;
    color: #64748b;
    font-weight: 500;
    font-size: 13px;
}

QTabBar::tab:selected {
    background: #ffffff;
    color: #1D6E5A;
    font-weight: 700;
    border: 2px solid #94a3b8;
    border-bottom: none;
}

QTabBar::tab:hover:!selected {
    background: #f1f5f9;
    color: #334155;
}

/* ---- Label ---- */
QLabel[heading="true"] {
    font-weight: 700;
    font-size: 20px;
    line-height: 1.3;
    color: #0f172a;
}

QLabel[subtitle="true"] {
    font-size: 12px;
    color: #64748b;
}

QLabel#appTitle {
    font-weight: 800;
    font-size: 32px;
    line-height: 1.15;
    color: #0f172a;
}

/* ---- List Widget ---- */
QListWidget {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 10px;
    padding: 6px;
    outline: none;
    color: #334155;
}

QListWidget::item {
    padding: 12px 16px;
    margin: 3px 6px;
    border-radius: 8px;
    color: #334155;
}

QListWidget::item:selected {
    background: #ecfdf5;
    color: #1D6E5A;
}

QListWidget::item:hover:!selected {
    background: #f1f5f9;
}

/* ---- Text Edit ---- */
QTextEdit {
    background: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 10px;
    padding: 12px 16px;
    color: #475569;
    font-size: 13px;
    line-height: 1.5;
    selection-background-color: #ecfdf5;
}

/* ---- Progress Bar ---- */
QProgressBar {
    border-radius: 5px;
    height: 10px;
    border: 2px solid #cbd5e1;
    background: #f1f5f9;
    text-align: center;
    font-size: 10px;
    color: transparent;
}

QProgressBar::chunk {
    background: #53C49E;
    border-radius: 5px;
}

/* ---- Dialog ---- */
QDialog {
    background: #f8fafc;
    border: 2px solid #94a3b8;
    border-radius: 16px;
}

/* ---- Gallery Thumbnails ---- */
QToolButton[galleryThumb="true"] {
    border-radius: 10px;
    border: 2px solid #cbd5e1;
    background: #ffffff;
    padding: 6px;
}

QToolButton[galleryThumb="true"]:hover {
    border-color: #1D6E5A;
}

QToolButton[galleryThumb="true"]:pressed {
    border-color: #165A48;
    background: #f1f5f9;
}

/* ---- Dialog Buttons ---- */
QDialogButtonBox QPushButton {
    padding: 8px 20px;
}

/* ---- Scroll Area Widget ---- */
QWidget#scrollContent {
    background: #f8fafc;
}

/* ---- Frame ---- */
QFrame {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
}

/* ---- Splitter ---- */
QSplitter {
    background: #e2e8f0;
}

QSplitter::handle {
    background: #cbd5e1;
    width: 4px;
}

QSplitter::handle:hover {
    background: #94a3b8;
}
