/* ============================================================
   Memories - Dark Theme
   Clean, modern dark design with clear visual hierarchy
   ============================================================ */

/* ---- Tooltip ---- */
QToolTip {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #475569;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
}

/* ---- Global ---- */
* {
    font-family: "Noto Sans SC", "WenQuanYi Micro Hei", "Sans Serif";
    font-size: 13px;
    color: #e2e8f0;
    line-height: 1.6;
}

QMainWindow {
    background: #0f172a;
}

QWidget#centralWidget {
    background: transparent;
}

/* ---- Scroll Areas ---- */
QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background: transparent;
}

QScrollBar:vertical {
    background: #1e293b;
    width: 8px;
    border-radius: 4px;
    margin: 4px 0;
}
QScrollBar::handle:vertical {
    background: #475569;
    border-radius: 4px;
    min-height: 40px;
}
QScrollBar::handle:vertical:hover {
    background: #64748b;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    border: none;
}
QScrollBar:horizontal {
    background: #1e293b;
    height: 8px;
    border-radius: 4px;
    margin: 0 4px;
}
QScrollBar::handle:horizontal {
    background: #475569;
    border-radius: 4px;
    min-width: 40px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    border: none;
}

/* ---- Menubar ---- */
QMenuBar {
    background: #1e293b;
    border-bottom: 1px solid #334155;
    padding: 4px 8px;
    font-size: 13px;
    font-weight: 500;
}

QMenuBar::item {
    padding: 6px 14px;
    margin: 2px 2px;
    border-radius: 6px;
    background: transparent;
    color: #94a3b8;
}

QMenuBar::item:selected {
    background: #0d9488;
    color: #f1f5f9;
}

QMenu {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 4px;
}

QMenu::item {
    padding: 8px 32px 8px 16px;
    margin: 1px 4px;
    border-radius: 6px;
    color: #94a3b8;
}

QMenu::item:selected {
    background: #0d9488;
    color: #f1f5f9;
}

/* ---- Toolbar ---- */
QToolBar {
    background: #1e293b;
    border-bottom: 1px solid #334155;
    padding: 4px 8px;
    spacing: 6px;
}

QToolBar QToolButton {
    padding: 6px 14px;
    margin: 1px;
    border-radius: 6px;
    color: #94a3b8;
    font-weight: 600;
    font-size: 12.5px;
    border: 1px solid #334155;
    background: #0f172a;
}

QToolBar QToolButton:hover {
    background: #0d9488;
    border-color: #0d9488;
    color: #f1f5f9;
}

QToolBar QToolButton:pressed {
    background: #0f766e;
}

QToolBar QToolButton:disabled {
    color: #475569;
    border-color: transparent;
    background: transparent;
}

/* ---- Status Bar ---- */
QStatusBar {
    background: #1e293b;
    border-top: 1px solid #334155;
    padding: 4px 12px;
    font-size: 12px;
    color: #64748b;
}

QStatusBar QLabel {
    color: #64748b;
    font-size: 12px;
}

/* ---- Push Buttons ---- */
QPushButton {
    padding: 8px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 13px;
    border: 1px solid transparent;
    min-height: 20px;
}

/* Primary button */
QPushButton[accent="true"], QPushButton#primaryBtn {
    background: #0d9488;
    color: #f1f5f9;
    border: none;
    font-weight: 700;
}

QPushButton[accent="true"]:hover, QPushButton#primaryBtn:hover {
    background: #0f766e;
}

QPushButton[accent="true"]:pressed, QPushButton#primaryBtn:pressed {
    background: #115e59;
}

/* Secondary / flat button */
QPushButton[flat="true"] {
    background: #0f172a;
    border: 1px solid #334155;
    color: #94a3b8;
}

QPushButton[flat="true"]:hover {
    background: #1e293b;
    border-color: #0d9488;
    color: #f1f5f9;
}

QPushButton[flat="true"]:pressed {
    background: #334155;
}

/* Default button (not accent/flat) */
QPushButton {
    background: #1e293b;
    border: 1px solid #334155;
    color: #cbd5e1;
}

QPushButton:hover {
    border-color: #0d9488;
    color: #f1f5f9;
}

QPushButton:pressed {
    background: #334155;
}

/* ---- Line Edit ---- */
QLineEdit {
    padding: 8px 14px;
    border-radius: 6px;
    border: 1px solid #334155;
    background: #0f172a;
    color: #e2e8f0;
    font-size: 13px;
    selection-background-color: #0d9488;
}

QLineEdit:focus {
    border-color: #0d9488;
}

QLineEdit:readonly {
    background: #1e293b;
    color: #64748b;
}

/* ---- ComboBox ---- */
QComboBox {
    padding: 8px 14px;
    border-radius: 6px;
    border: 1px solid #334155;
    background: #0f172a;
    color: #e2e8f0;
    font-size: 13px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: #475569;
}

QComboBox:focus {
    border-color: #0d9488;
}

QComboBox::drop-down {
    border: none;
    padding-right: 8px;
}

QComboBox QAbstractItemView {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    padding: 4px;
    selection-background-color: #0d9488;
    color: #e2e8f0;
}

/* ---- SpinBox ---- */
QSpinBox {
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid #334155;
    background: #0f172a;
    color: #e2e8f0;
    font-size: 13px;
}

QSpinBox:focus {
    border-color: #0d9488;
}

/* ---- Checkbox ---- */
QCheckBox {
    spacing: 8px;
    color: #cbd5e1;
    font-size: 13px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid #475569;
    background: #0f172a;
}

QCheckBox::indicator:checked {
    background: #0d9488;
    border-color: #0d9488;
}

QCheckBox::indicator:hover {
    border-color: #0d9488;
}

/* ---- GroupBox (cards) ---- */
QGroupBox {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    margin-top: 20px;
    padding: 24px 16px 16px 16px;
    font-weight: 700;
    font-size: 13px;
    color: #e2e8f0;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 14px;
    margin-left: 16px;
    background: #1e293b;
    border-radius: 6px;
    border: 1px solid #334155;
}

/* ---- Tab Widget ---- */
QTabWidget::pane {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 8px;
}

QTabBar::tab {
    padding: 8px 20px;
    margin: 2px 4px;
    border-radius: 6px;
    background: transparent;
    color: #64748b;
    font-weight: 500;
    font-size: 13px;
}

QTabBar::tab:selected {
    background: #1e293b;
    color: #0d9488;
    font-weight: 700;
    border: 1px solid #334155;
    border-bottom: none;
}

QTabBar::tab:hover:!selected {
    background: #334155;
    color: #cbd5e1;
}

/* ---- Label ---- */
QLabel[heading="true"] {
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    color: #f1f5f9;
}

QLabel[subtitle="true"] {
    font-size: 12px;
    color: #64748b;
}

QLabel#appTitle {
    font-weight: 800;
    font-size: 28px;
    line-height: 1.15;
    color: #f1f5f9;
}

/* ---- List Widget ---- */
QListWidget {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 4px;
    outline: none;
    color: #cbd5e1;
}

QListWidget::item {
    padding: 10px 14px;
    margin: 2px 4px;
    border-radius: 6px;
    color: #cbd5e1;
}

QListWidget::item:selected {
    background: #0d9488;
    color: #f1f5f9;
}

QListWidget::item:hover:!selected {
    background: #334155;
}

/* ---- Text Edit ---- */
QTextEdit {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 10px 14px;
    color: #94a3b8;
    font-size: 13px;
    line-height: 1.5;
    selection-background-color: #0d9488;
}

/* ---- Progress Bar ---- */
QProgressBar {
    border-radius: 4px;
    height: 8px;
    border: 1px solid #334155;
    background: #0f172a;
    text-align: center;
    font-size: 10px;
    color: transparent;
}

QProgressBar::chunk {
    background: #0d9488;
    border-radius: 4px;
}

/* ---- Dialog ---- */
QDialog {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 12px;
}

/* ---- Gallery Thumbnails ---- */
QToolButton[galleryThumb="true"] {
    border-radius: 8px;
    border: 2px solid #334155;
    background: #1e293b;
    padding: 4px;
}

QToolButton[galleryThumb="true"]:hover {
    border-color: #0d9488;
}

QToolButton[galleryThumb="true"]:pressed {
    border-color: #0f766e;
    background: #334155;
}

/* ---- Dialog Buttons ---- */
QDialogButtonBox QPushButton {
    padding: 6px 16px;
}

/* ---- Scroll Area Widget ---- */
QWidget#scrollContent {
    background: transparent;
}
